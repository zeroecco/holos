{
  "api_version": "holos/v1alpha1",
  "kind": "Service",
  "name": "web",
  "replicas": 2,
  "image": "../output/images/base/holosteric-base.qcow2",
  "image_format": "qcow2",
  "vm": {
    "vcpu": 1,
    "memory_mb": 768
  },
  "ports": [
    {
      "name": "http",
      "host_port": 8080,
      "guest_port": 80,
      "protocol": "tcp"
    }
  ],
  "mounts": [
    {
      "source": "../examples/www",
      "target": "/srv/www",
      "read_only": true
    }
  ],
  "cloud_init": {
    "user": "ubuntu",
    "packages": ["nginx"],
    "write_files": [
      {
        "path": "/var/www/html/index.html",
        "content": "<html><body><h1>holosteric</h1><p>KVM, not containers.</p></body></html>\n",
        "permissions": "0644",
        "owner": "root:root"
      }
    ],
    "runcmd": [
      "systemctl enable nginx",
      "systemctl restart nginx"
    ]
  }
}
